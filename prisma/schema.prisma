generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum MediaSourceType {
  UPLOAD
  YOUTUBE
}

enum MediaTaskStatus {
  UPLOADING
  QUEUED
  PROCESSING
  TRANSCRIBING
  ANALYZING
  COMPLETED
  FAILED
  CANCELED
}

enum InsightType {
  SUMMARY
  MIND_MAP
  QA
  TRANSLATION
}

enum ExportFormat {
  TXT
  SRT
  VTT
  JSON
  PDF
}

model User {
  /// 用户唯一 ID
  id             String         @id @default(cuid())
  /// 用户邮箱
  email          String         @unique
  /// 用户显示名称
  name           String?
  /// 用户头像 URL
  image          String?
  /// 用户首选界面语言
  locale         String         @default("en")
  /// 免费用户当日已使用次数
  dailyFreeCount Int            @default(0)
  /// 免费次数下次重置时间
  dailyResetAt   DateTime?
  /// 用户创建时间
  createdAt      DateTime       @default(now())
  /// 用户更新时间
  updatedAt      DateTime       @updatedAt
  subscriptions  Subscription[]
  mediaTasks     MediaTask[]
}

model Subscription {
  /// 订阅记录 ID
  id                   String             @id @default(cuid())
  /// 关联用户 ID
  userId               String
  /// 订阅套餐
  plan                 SubscriptionPlan   @default(FREE)
  /// Stripe 订阅状态
  status               SubscriptionStatus @default(ACTIVE)
  /// Stripe 客户 ID
  stripeCustomerId     String?            @unique
  /// Stripe 订阅 ID
  stripeSubscriptionId String?            @unique
  /// 每月分钟额度
  monthlyMinuteQuota   Int                @default(90)
  /// 剩余可用分钟数
  remainingMinutes     Int                @default(90)
  /// 单次任务最大音视频分钟数
  maxSingleFileMinutes Int                @default(30)
  /// 单文件上传大小上限
  maxUploadBytes       BigInt             @default(2147483648)
  /// 当前账期开始时间
  currentPeriodStart   DateTime?
  /// 当前账期结束时间
  currentPeriodEnd     DateTime?
  /// 订阅创建时间
  createdAt            DateTime           @default(now())
  /// 订阅更新时间
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MediaTask {
  /// 转写任务 ID
  id               String          @id @default(cuid())
  /// 关联用户 ID，匿名用户为空
  userId           String?
  /// 来源类型：上传或 YouTube
  sourceType       MediaSourceType
  /// 原始文件名或视频标题
  originalName     String?
  /// 原始媒体 URL、R2 对象 URL 或 YouTube 链接
  sourceUrl        String          @db.VarChar(2048)
  /// FFmpeg 预处理后的音频 URL
  normalizedUrl    String?         @db.VarChar(2048)
  /// R2 对象存储 Key
  objectKey        String?
  /// 当前处理状态
  status           MediaTaskStatus @default(UPLOADING)
  /// 面向用户的状态说明或错误摘要
  statusMessage    String?         @db.VarChar(1024)
  /// 转写语言代码，auto 表示自动检测
  language         String?
  /// 服务商检测到的语言代码
  detectedLanguage String?
  /// 音视频时长（秒）
  durationSeconds  Int?
  /// 原始文件大小（字节）
  fileSizeBytes    BigInt?
  /// 实际完成转写的服务商
  provider         String?
  /// 识别到的发言人数
  speakerCount     Int?
  /// 处理进度百分比
  progress         Int             @default(0)
  /// 本任务扣减的额度分钟数
  quotaMinutes     Int             @default(0)
  /// 错误代码
  errorCode        String?
  /// 任务创建时间
  createdAt        DateTime        @default(now())
  /// 任务更新时间
  updatedAt        DateTime        @updatedAt
  /// 任务完成时间
  completedAt      DateTime?
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  transcript       Transcript?
  insights         AIInsight[]
  exports          ExportAsset[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model Transcript {
  /// 转写文本 ID
  id          String    @id @default(cuid())
  /// 关联转写任务 ID
  mediaTaskId String    @unique
  /// 完整纯文本转写结果
  plainText   String    @db.LongText
  /// 带时间戳和发言人标签的段落 JSON
  segments    Json
  /// 词级时间戳与置信度 JSON
  words       Json?
  /// 用户编辑后的文本
  editedText  String?   @db.LongText
  /// 转写结果创建时间
  createdAt   DateTime  @default(now())
  /// 转写结果更新时间
  updatedAt   DateTime  @updatedAt
  mediaTask   MediaTask @relation(fields: [mediaTaskId], references: [id], onDelete: Cascade)
}

model AIInsight {
  /// AI 洞察 ID
  id          String      @id @default(cuid())
  /// 关联转写任务 ID
  mediaTaskId String
  /// 洞察类型：总结、问答、思维导图、翻译
  type        InsightType
  /// 洞察生成语言
  locale      String      @default("en")
  /// 洞察标题
  title       String?
  /// 洞察结构化内容 JSON
  content     Json
  /// 生成洞察使用的模型
  model       String?
  /// 洞察创建时间
  createdAt   DateTime    @default(now())
  /// 洞察更新时间
  updatedAt   DateTime    @updatedAt
  mediaTask   MediaTask   @relation(fields: [mediaTaskId], references: [id], onDelete: Cascade)

  @@unique([mediaTaskId, type, locale])
}

model ExportAsset {
  /// 导出文件 ID
  id          String       @id @default(cuid())
  /// 关联转写任务 ID
  mediaTaskId String
  /// 导出格式
  format      ExportFormat
  /// R2 对象 Key
  objectKey   String?
  /// 导出文件访问 URL
  url         String?      @db.VarChar(2048)
  /// 导出创建时间
  createdAt   DateTime     @default(now())
  mediaTask   MediaTask    @relation(fields: [mediaTaskId], references: [id], onDelete: Cascade)

  @@index([mediaTaskId, format])
}
