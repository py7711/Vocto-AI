DATABASE_URL="mysql://USER:PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/uniscribe?sslaccept=strict"
PRISMA_TRANSACTION_MAX_WAIT_MS="10000"
PRISMA_TRANSACTION_TIMEOUT_MS="20000"

# Redis 协议地址。本地部署用 redis://127.0.0.1:6379；云 Redis 用 rediss://...
# 不要把 UPSTASH_REDIS_REST_URL 填在这里；REST 地址不支持 BullMQ 阻塞命令。
REDIS_URL="redis://127.0.0.1:6379"
# 也支持使用 UPSTASH_REDIS_URL 或 KV_URL
# UPSTASH_REDIS_REST_TOKEN=""
TRANSCRIBE_QUEUE="uniscribe-transcribe"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="please-change-this-to-a-long-random-secret"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="uniscribe-media"
R2_PUBLIC_BASE_URL=""

GROQ_API_KEY=""
DEEPGRAM_API_KEY=""
ASSEMBLYAI_API_KEY=""
OPENAI_API_KEY=""

# 转写服务商 webhook 回调基础地址（需公网可达）；留空时回退到 NEXT_PUBLIC_APP_URL。
# 本地开发可用内网穿透（如 ngrok）暴露 /api/transcription/callback/*。
TRANSCRIPTION_CALLBACK_BASE_URL=""
# 提交异步转写后等待回调的最长秒数，超时自动查询服务商 API 兜底。
TRANSCRIPTION_CALLBACK_TIMEOUT_SECONDS="1200"
# 未收到回调时轮询服务商结果的间隔秒数。
TRANSCRIPTION_POLL_INTERVAL_SECONDS="6"

# AI 洞察模型降级链：deepseek-v4 -> Gemini -> Groq -> 本地兜底
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_CHAT_MODEL="deepseek-v4"
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# 翻译降级链：DeepL -> deepseek-v4-flash -> 本地原文兜底
DEEPL_API_KEY=""
DEEPL_API_URL="https://api-free.deepl.com/v2/translate"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# 订阅套餐 Stripe Price ID，必须是 price_...，不要填写 prod_... 产品 ID。旧变量 STRIPE_PRICE_BASIC/STANDARD/PRO 仍作为月付兼容；新部署建议使用 *_MONTHLY。
# 订阅套餐 Stripe Price ID。旧变量 STRIPE_PRICE_BASIC/STANDARD/PRO 仍作为月付兼容；新部署建议使用 *_MONTHLY。
STRIPE_PRICE_BASIC_MONTHLY="price_1TrcRb85Iq5xwbY6Ad73y5Gh"
STRIPE_PRICE_STANDARD_MONTHLY="price_1TrcUv85Iq5xwbY6NrNN6Uw8"
STRIPE_PRICE_PRO_MONTHLY="price_1TrcX285Iq5xwbY6tmW5bIq5"
STRIPE_PRICE_BASIC_ANNUAL="price_1Trcan85Iq5xwbY6fMYkZXNB"
STRIPE_PRICE_STANDARD_ANNUAL="price_1Trcd485Iq5xwbY63nIvPTzE"
STRIPE_PRICE_PRO_ANNUAL="price_1Trcta85Iq5xwbY6i0kw6npi"
# 一次性分钟包 Stripe Price ID。
STRIPE_PRICE_LITE="price_1TratP85Iq5xwbY6De3JTqFB"
STRIPE_PRICE_PLUS="price_1TrcFU85Iq5xwbY6YojYqoA0"
# 已订阅用户加购分钟包 Stripe Price ID。
STRIPE_PRICE_ADDON_BASIC="price_1TrdLi85Iq5xwbY6keQ5F2s6"
STRIPE_PRICE_ADDON_STANDARD="price_1TrdN185Iq5xwbY6uMPSuegp"
STRIPE_PRICE_ADDON_PRO="price_1TrdQL85Iq5xwbY6HPoUrK0g"

# Annual Basic 限时活动。推荐填写 Stripe Promotion Code ID（promo_...）；也可填写 Coupon ID。
# 都为空时，后端默认用用户可见促销码 BFY60 查询 Stripe active promotion code。
STRIPE_BASIC_ANNUAL_PROMOTION_CODE_ID="promo_1TrdjN85Iq5xwbY6sZcg0jLO"
#STRIPE_BASIC_ANNUAL_COUPON_ID="baD95rfG"
#STRIPE_BASIC_ANNUAL_PROMOTION_CODE="BFY60"

# 邮箱验证：优先使用 SMTP（如 Spacemail）；未配置 SMTP_HOST 时回退到 Resend REST API；两者都未配置时仅生成验证链接，不实际发送。
EMAIL_FROM="UniScribe <no-reply@example.com>"

# SMTP 发信配置（示例：Spacemail）
SMTP_HOST="mail.spacemail.com"
SMTP_PORT="465"
# 465 端口默认使用隐式 TLS（SMTPS），无需单独配置；如使用 587 端口请设置 SMTP_SECURE="false"
SMTP_USER="admin@example.com"
SMTP_PASSWORD=""

# 备用：Resend REST API（未配置 SMTP_HOST 时生效）
RESEND_API_KEY=""

# Google OAuth 登录
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_API_KEY=""

# 可选：yt-dlp 可执行文件路径。未配置时会依次尝试 yt-dlp、python3 -m yt_dlp、python -m yt_dlp。
# Docker Compose 会覆盖为 /opt/votxt/bin/yt-dlp（镜像内锁定 2026.06.09），宿主机可不装 yt-dlp。
# 示例：YT_DLP_PATH="/opt/votxt/bin/yt-dlp"
YT_DLP_PATH=""
# 可选：Netscape 格式 YouTube cookies，用于绕过 AWS IP 的 bot 检测。
# Docker 宿主机固定放：/data/config/youtube-cookies.txt ，容器内映射为 /config/youtube-cookies.txt。
# YT_DLP_COOKIES_PATH="/data/config/youtube-cookies.txt"
