DATABASE_URL="mysql://USER:PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/uniscribe?sslaccept=strict"
PRISMA_TRANSACTION_MAX_WAIT_MS="10000"
PRISMA_TRANSACTION_TIMEOUT_MS="20000"

# BullMQ 需要 Upstash Redis 协议地址，通常是 rediss://...
# 不要把 UPSTASH_REDIS_REST_URL 填在这里；REST 地址不支持队列阻塞命令。
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"
# 也支持使用 UPSTASH_REDIS_URL 或 KV_URL
# 如果平台自动注入 UPSTASH_REDIS_REST_TOKEN，可以保留；BullMQ 不会读取 REST token。
UPSTASH_REDIS_REST_TOKEN=""
TRANSCRIBE_QUEUE="uniscribe-transcribe"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="please-change-this-to-a-long-random-secret"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="uniscribe-media"
R2_PUBLIC_BASE_URL=""

GROQ_API_KEY=""
DEEPGRAM_API_KEY=""
ASSEMBLYAI_API_KEY=""
OPENAI_API_KEY=""

# AI 洞察模型降级链：deepseek-v4 -> Gemini -> Groq -> 本地兜底
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_CHAT_MODEL="deepseek-v4"
DEEPSEEK_FLASH_MODEL="deepseek-v4-flash"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"

# 翻译降级链：DeepL -> deepseek-v4-flash -> 本地原文兜底
DEEPL_API_KEY=""
DEEPL_API_URL="https://api-free.deepl.com/v2/translate"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_BASIC=""
STRIPE_PRICE_STANDARD=""
STRIPE_PRICE_PRO=""

# 邮箱验证：优先使用 Resend REST API；不配置时仅生成验证链接，不实际发送。
RESEND_API_KEY=""
EMAIL_FROM="UniScribe <no-reply@example.com>"

# Google OAuth 登录
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_API_KEY=""

# 可选：yt-dlp 可执行文件路径。未配置时会依次尝试 yt-dlp、python3 -m yt_dlp、python -m yt_dlp。
# 示例：YT_DLP_PATH="/usr/local/bin/yt-dlp"
YT_DLP_PATH=""
